  7362                           ;	Power-up timer selection bits
  7363                           ;	PWRTS = PWRT_OFF, PWRT is disabled
  7364                           ;	Multi-vector enable bit
  7365                           ;	MVECEN = OFF, Interrupt contoller does not use vector table to prioritze interrupts
  7366                           ;	IVTLOCK bit One-way set enable bit
  7367                           ;	IVT1WAY = ON, IVTLOCK bit can be cleared and set only once
  7368                           ;	Low Power BOR Enable bit
  7369                           ;	LPBOREN = OFF, ULPBOR disabled
